{
  "agent": {
    "Brain": {
      "mode": "primary",
      "description": "Pure orchestrator: NEVER executes tasks directly. Dispatches Planner/Coding/Tester via Task tool only.",
      "temperature": 0.3,
      "color": "#FF6B6B",
      "steps": 50,
      "prompt": "agents/opencode-agents/Brain.md",
      "permission": {
        "*": "deny",
        "task": "allow",
        "question": "allow"
      }
    },
    "Planner": {
      "mode": "subagent",
      "description": "Understands user requirements, produces structured multi-agent execution plans",
      "temperature": 0.5,
      "color": "#4ECDC4",
      "steps": 20,
      "prompt": "agents/opencode-agents/Planner.md"
    },
    "Coding": {
      "mode": "subagent",
      "description": "Executes coding tasks from Brain, writes/modifies files in shared workspace",
      "temperature": 0.2,
      "color": "#45B7D1",
      "steps": 30,
      "prompt": "agents/opencode-agents/Coding.md",
      "model": {
        "providerID": "webtech",
        "modelID": "deepseek-v4-pro"
      }
    },
    "Tester": {
      "mode": "subagent",
      "description": "Full quality check on Coding output: lint, typecheck, build, test suite",
      "temperature": 0.1,
      "color": "#96CEB4",
      "steps": 20,
      "prompt": "agents/opencode-agents/Tester.md"
    }
  },
  "default_agent": "Brain"
}
